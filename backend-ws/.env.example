PORT=3001
NODE_ENV=development

# OpenAI API Key for AI-powered NLP (optional - will fallback to regex if not provided)
OPENAI_API_KEY=sk-your-openai-api-key-here

# BookMyShow Credentials (optional)
BOOKMYSHOW_EMAIL=your-email@example.com
BOOKMYSHOW_PASSWORD=your-password

# Optional: Notification settings
ENABLE_NOTIFICATIONS=true
